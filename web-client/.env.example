# => COPY AND EDIT THIS FILE TO CREATE YOUR CUSTOM .env.*.local FILES.

# Use settings like these to create your .env.development.local file:
# NEXT_PUBLIC_WEB_CLIENT_URL=http://localhost:3000
# NEXT_PUBLIC_SERVER_URL=http://localhost:8080/api
# NEXT_PUBLIC_GRAPHQL_ENDPOINT_URL=http://localhost:8080/api/graphql

# Use settings like these to create your .env.production.local file:
# NEXT_PUBLIC_WEB_CLIENT_URL=https://MY_PRODUCTION_SERVER
# NEXT_PUBLIC_SERVER_URL=https://MY_PRODUCTION_SERVER/api
# NEXT_PUBLIC_GRAPHQL_ENDPOINT_URL=https://MY_PRODUCTION_SERVER/api/graphql
